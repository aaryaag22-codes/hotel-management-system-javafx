<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<!--
    login.fxml
    This file is the Scene Builder FXML layout for the Hotel Login Screen.
    It is loaded by FXMLLoader in App.java — this is how Scene Builder integrates
    with JavaFX. You can open this file directly in Scene Builder to visually edit it.
-->
<StackPane
    xmlns="http://javafx.openjfx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.hotel.ui.LoginController"
    prefWidth="900" prefHeight="600"
    style="-fx-background-color: #1A1A2E;">

    <!-- Background decorative layers -->
    <VBox alignment="CENTER" style="-fx-background-color: transparent;">

        <!-- Top gold accent bar -->
        <Region prefHeight="4" prefWidth="900"
                style="-fx-background-color: linear-gradient(to right, transparent, #C9A84C, transparent);"/>

        <!-- Main content card -->
        <VBox alignment="CENTER" spacing="0"
              maxWidth="460" maxHeight="520"
              style="-fx-background-color: #16213E;
                     -fx-background-radius: 18;
                     -fx-border-color: #C9A84C55;
                     -fx-border-radius: 18;
                     -fx-border-width: 1;
                     -fx-effect: dropshadow(gaussian, #00000099, 30, 0, 0, 10);">

            <!-- Hotel logo area -->
            <VBox alignment="CENTER" spacing="6"
                  style="-fx-background-color: linear-gradient(to bottom, #0F3460, #16213E);
                         -fx-background-radius: 18 18 0 0;
                         -fx-padding: 36 40 28 40;">

                <Label text="🏨"
                       style="-fx-font-size: 52px;"/>

                <Label text="GRAND VISTA HOTEL"
                       style="-fx-text-fill: #C9A84C;
                              -fx-font-size: 22px;
                              -fx-font-weight: bold;
                              -fx-font-family: 'Georgia';"/>

                <Label text="Management System"
                       style="-fx-text-fill: #A0A0B0;
                              -fx-font-size: 13px;
                              -fx-font-style: italic;"/>

                <!-- Decorative divider -->
                <Region prefHeight="1" prefWidth="200"
               style="-fx-background-color: #C9A84C66;"/>
            </VBox>

            <!-- Login form area -->
            <VBox spacing="16"
                  style="-fx-padding: 32 44 36 44;">

                <!-- Username field -->
                <VBox spacing="6">
                    <Label text="Username"
                           style="-fx-text-fill: #A0A0B0;
                                  -fx-font-size: 11px;
                                  -fx-font-weight: bold;"/>
                    <TextField fx:id="usernameField"
                               promptText="Enter username"
                               style="-fx-background-color: #0D2137;
                                      -fx-text-fill: #EAEAEA;
                                      -fx-prompt-text-fill: #505068;
                                      -fx-border-color: #0F3460;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 11 14;
                                      -fx-font-size: 13px;"/>
                </VBox>

                <!-- Password field -->
                <VBox spacing="6">
                    <Label text="Password"
                           style="-fx-text-fill: #A0A0B0;
                                  -fx-font-size: 11px;
                                  -fx-font-weight: bold;"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Enter password"
                                   style="-fx-background-color: #0D2137;
                                          -fx-text-fill: #EAEAEA;
                                          -fx-prompt-text-fill: #505068;
                                          -fx-border-color: #0F3460;
                                          -fx-border-radius: 8;
                                          -fx-background-radius: 8;
                                          -fx-padding: 11 14;
                                          -fx-font-size: 13px;"/>
                </VBox>

                <!-- Error message label (hidden by default) -->
                <Label fx:id="errorLabel"
                       text=""
                       style="-fx-text-fill: #E74C3C;
                              -fx-font-size: 12px;
                              -fx-font-style: italic;"
                       visible="false"
                       managed="false"/>

                <!-- Login button -->
                <Button fx:id="loginButton"
                        text="🔑  Sign In"
                        prefWidth="Infinity"
                        onAction="#handleLogin"
                        style="-fx-background-color: linear-gradient(to right, #C9A84C, #A07830);
                               -fx-text-fill: #1A1A2E;
                               -fx-font-weight: bold;
                               -fx-font-size: 14px;
                               -fx-padding: 12 0;
                               -fx-background-radius: 8;
                               -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, #C9A84C66, 10, 0, 0, 3);"/>

                <!-- Hint -->
                <Label text="Default: admin / admin123"
                       style="-fx-text-fill: #505068;
                              -fx-font-size: 10px;
                              -fx-font-style: italic;"
                       alignment="CENTER"
                       prefWidth="Infinity"/>

            </VBox>

        </VBox>

        <!-- Bottom accent bar -->
        <Region prefHeight="4" prefWidth="900"
                style="-fx-background-color: linear-gradient(to right, transparent, #C9A84C, transparent);"/>
    </VBox>

</StackPane>
